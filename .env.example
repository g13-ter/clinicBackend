# Copy this file to .env and fill in real values.
# Never commit the actual .env file - it's already in .gitignore.

# MongoDB connection string (e.g. from MongoDB Atlas)
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<database-name>
MONGO_URI=

# Secret used to sign JWT auth tokens.
# Use a long, random string - do NOT reuse this value across environments
# (local, staging, production should each have their own).
JWT_SECRET=

# How long a login token stays valid before the user has to log in again.
# Optional - defaults to "1d" if not set. Examples: "1h", "7d", "30m"
JWT_EXPIRE=1d

# Port the server listens on locally.
# Optional - defaults to 5000 if not set.
# Note: on Railway (and most hosts), this is injected automatically
# and does not need to be set manually.
PORT=5000

# Set automatically to "production" by most hosting platforms (e.g. Railway).
# Leave unset for local development - the app behaves correctly either way.
# NODE_ENV=production

# Used only by tests/seedAdmin.ts (one-time script to create the first
# admin account). Optional - defaults to admin@clinic.com / admin123
# if not set, which is fine for local dev only. Before running this
# script against a real/production database, set real values here
# so the default credentials are never used outside local testing.
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=